# Sanity Studio
SANITY_STUDIO_PROJECT_ID=ffetz19f
SANITY_STUDIO_DATASET=production

# Instructions:
# 1. Go to https://sanity.io/manage and create a new project
# 2. Copy your Project ID and paste it above
# 3. Create an API token at https://sanity.io/manage -> API -> Add token (Editor role)
# 4. Run: node scripts/migrate-to-sanity.js <YOUR_TOKEN>
# 5. Then run: npm run dev (in studio/) to start Sanity Studio

